# Optional: copy to `backend.hcl` (gitignored) and pass the same -backend-config as `scripts/deploy.sh`
# for one-off `terraform` commands, after the state bucket exists.
#
# First local apply with S3 not configured:
#   terraform init -reconfigure -backend=false
#   terraform apply
# Then migrate, using the bucket/lock from outputs and `key` = env/<environment>/terraform.tfstate (match deploy.sh):
#
#   terraform init -migrate-state -backend-config=bucket=... -backend-config="key=env/dev/terraform.tfstate" ...

bucket         = "REPLACE_WITH_terraform_state_bucket_name"
key            = "env/dev/terraform.tfstate"
region         = "us-east-1" # must match the bucket
dynamodb_table = "REPLACE_WITH_terraform_state_lock_table_name"
encrypt        = true
